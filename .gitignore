# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
*.tsbuildinfo

# Test / coverage
coverage/
.vitest/

# Local kv state that must never be committed
.kv/local.json

# Editor / OS
.DS_Store
*.log

# Local Claude Code settings
.claude/
.mcp.json

# Env files (kv exists to replace these, but guard anyway)
.env
.env.*
!.env.example

# Never commit the npm publish token / local npm auth
.npmrc

# Never commit local private working files into the public repo
docs/private/
**/private-plans/
*.private.md
